# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Full Postgres connection string (used by Drizzle ORM)
DATABASE_URL=postgresql://user:password@localhost:5432/climatetwin

# Individual Postgres credentials (alternative to DATABASE_URL)
PGHOST=localhost
PGPORT=5432
PGDATABASE=climatetwin
PGUSER=user
PGPASSWORD=password

# ─── API Server ───────────────────────────────────────────────────────────────
# Port the Express API server listens on
PORT=8080

# Node environment (development | production)
NODE_ENV=development

# Log level for pino logger (trace | debug | info | warn | error)
LOG_LEVEL=info

# Session secret for signed cookies (generate a strong random string for production)
SESSION_SECRET=change-me-to-a-long-random-string-in-production

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Vite dev server port (the frontend artifact)
VITE_PORT=3000

# ─── Future API Integrations (plug in real keys when available) ───────────────
# IMD (India Meteorological Department) – API key for live weather data
IMD_API_KEY=

# OpenWeather API – fallback weather data
OPENWEATHER_API_KEY=

# NASA POWER API – solar and meteorological data (no key required for basic use)
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api

# ISRO MOSDAC – satellite data (institutional access required)
MOSDAC_API_KEY=

# CPCB (Central Pollution Control Board) – AQI data
CPCB_API_KEY=

# CWC (Central Water Commission) – river and reservoir data
CWC_API_KEY=
